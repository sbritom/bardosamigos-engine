<icecast>
  <location>Bar dos Amigos</location>
  <admin>admin@bardosamigos.local</admin>
  <hostname>localhost</hostname>

  <limits>
    <clients>100</clients>
    <sources>2</sources>
    <queue-size>524288</queue-size>
    <client-timeout>30</client-timeout>
    <header-timeout>15</header-timeout>
    <source-timeout>10</source-timeout>
    <burst-on-connect>1</burst-on-connect>
    <burst-size>65535</burst-size>
  </limits>

  <authentication>
    <source-password>hackme</source-password>
    <relay-password>relay</relay-password>
    <admin-user>admin</admin-user>
    <admin-password>admin</admin-password>
  </authentication>

  <listen-socket>
    <port>8000</port>
  </listen-socket>

  <mount>
    <mount-name>/radio</mount-name>
    <public>1</public>
    <stream-name>Radio Bar dos Amigos</stream-name>
    <stream-description>A trilha sonora da nossa amizade</stream-description>
    <stream-url>http://localhost:8000/radio</stream-url>
    <genre>Community Radio</genre>
    <bitrate>128</bitrate>
  </mount>

  <fileserve>1</fileserve>
  <paths>
    <logdir>./logs</logdir>
    <webroot>./web</webroot>
    <adminroot>./admin</adminroot>
    <alias source="/" destination="/status.xsl"/>
  </paths>

  <logging>
    <accesslog>access.log</accesslog>
    <errorlog>error.log</errorlog>
    <loglevel>3</loglevel>
    <logsize>10000</logsize>
  </logging>
</icecast>
