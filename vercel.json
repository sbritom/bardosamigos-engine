{
  "crons": [
    {
      "path": "/api/cron/sync-news",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/sync-news",
      "schedule": "0 21 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
