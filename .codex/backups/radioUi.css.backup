.bar-radio-page {
  width: min(1180px, calc(100% - 32px));
  margin: 0 auto;
  color: #eef5ff;
}

.bar-radio-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  padding: 22px;
  border: 1px solid rgba(106, 142, 190, 0.22);
  border-radius: 8px;
  background: linear-gradient(135deg, rgba(4, 12, 24, 0.96), rgba(10, 24, 44, 0.94));
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.28);
}

.bar-radio-brand {
  display: flex;
  align-items: center;
  gap: 14px;
  min-width: 0;
}

.bar-radio-logo {
  display: grid;
  width: 54px;
  height: 54px;
  place-items: center;
  border: 1px solid rgba(235, 190, 92, 0.45);
  border-radius: 8px;
  color: #f2c66d;
  background: rgba(242, 198, 109, 0.08);
}

.bar-radio-brand p,
.bar-radio-kicker {
  color: #8fb4de;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0;
  text-transform: uppercase;
}

.bar-radio-brand h1 {
  margin-top: 2px;
  font-size: clamp(1.7rem, 3vw, 2.8rem);
  line-height: 1;
}

.bar-radio-live,
.bar-radio-mini-live {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  white-space: nowrap;
  font-weight: 800;
}

.bar-radio-live {
  padding: 10px 14px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.06);
}

.bar-radio-live small {
  color: #9cb3ce;
  font-weight: 600;
}

.bar-radio-live.is-online {
  color: #5df29a;
}

.bar-radio-live.is-offline {
  color: #ff7272;
}

.bar-radio-layout {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 360px;
  gap: 18px;
  margin-top: 18px;
}

.bar-radio-main-column,
.bar-radio-side-column,
.bar-radio-player-stack {
  display: grid;
  gap: 18px;
}

.bar-radio-card {
  border: 1px solid rgba(106, 142, 190, 0.2);
  border-radius: 8px;
  background: rgba(6, 16, 31, 0.92);
  box-shadow: 0 16px 44px rgba(0, 0, 0, 0.24);
}

.bar-radio-now {
  display: grid;
  grid-template-columns: 300px minmax(0, 1fr);
  gap: 24px;
  padding: 22px;
}

.bar-radio-cover-wrap {
  aspect-ratio: 1;
  min-width: 0;
}

.bar-radio-cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 8px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: #101a29;
}

.bar-radio-cover--empty {
  display: grid;
  place-items: center;
  color: #7996b6;
}

.bar-radio-now-content {
  min-width: 0;
  align-self: center;
}

.bar-radio-now-content h2 {
  margin-top: 8px;
  font-size: clamp(2rem, 4vw, 4rem);
  line-height: 1;
  overflow-wrap: anywhere;
}

.bar-radio-artist {
  margin-top: 10px;
  color: #f2c66d;
  font-size: 1.2rem;
  font-weight: 800;
}

.bar-radio-meta-grid,
.bar-radio-stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  margin-top: 18px;
}

.bar-radio-meta-grid span,
.bar-radio-stats-grid span {
  min-width: 0;
  padding: 10px;
  border-radius: 8px;
  color: #c8d7ea;
  background: rgba(255, 255, 255, 0.05);
  overflow-wrap: anywhere;
}

.bar-radio-progress-row {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  align-items: center;
  gap: 10px;
  margin-top: 20px;
  color: #9db5d2;
  font-variant-numeric: tabular-nums;
}

.bar-radio-progress {
  height: 8px;
  overflow: hidden;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.1);
}

.bar-radio-progress span {
  display: block;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #4da3ff, #f2c66d);
}

.bar-radio-mini,
.bar-radio-compact,
.bar-radio-player-status {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px;
}

.bar-radio-mini {
  justify-content: space-between;
}

.bar-radio-mini-live {
  color: #ff5f6d;
}

.bar-radio-mini-track {
  display: grid;
  flex: 1;
  min-width: 0;
}

.bar-radio-mini-track strong,
.bar-radio-track-row strong {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bar-radio-mini-track span,
.bar-radio-track-row span,
.bar-radio-card > span,
.bar-radio-inline-warning {
  color: #9fb5cf;
}

.bar-radio-round-button,
.bar-radio-icon-button,
.bar-radio-primary-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 0;
  color: #07111f;
  background: #f2c66d;
}

.bar-radio-round-button {
  width: 42px;
  height: 42px;
  border-radius: 50%;
}

.bar-radio-icon-button {
  width: 38px;
  height: 38px;
  border-radius: 8px;
}

.bar-radio-primary-button {
  gap: 8px;
  min-height: 42px;
  padding: 0 18px;
  border-radius: 8px;
  font-weight: 800;
}

.bar-radio-primary-button:disabled {
  cursor: not-allowed;
  opacity: 0.5;
}

.bar-radio-compact input {
  flex: 1;
  min-width: 80px;
}

.bar-radio-player-status {
  justify-content: space-between;
}

.bar-radio-player-status div {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: #cbd9eb;
}

.bar-radio-full-player {
  display: grid;
  gap: 10px;
}

.bar-radio-inline-warning {
  margin: -6px 4px 0;
  font-size: 0.92rem;
}

.bar-radio-card-title {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 16px 16px 0;
  color: #f2c66d;
}

.bar-radio-card-title h3 {
  font-size: 1rem;
}

.bar-radio-list {
  display: grid;
  gap: 10px;
  padding: 14px;
}

.bar-radio-track-row {
  display: grid;
  grid-template-columns: 46px minmax(0, 1fr);
  align-items: center;
  gap: 10px;
  min-width: 0;
}

.bar-radio-track-row img {
  width: 46px;
  height: 46px;
  object-fit: cover;
  border-radius: 8px;
  background: #111b2a;
}

.bar-radio-track-row div {
  display: grid;
  min-width: 0;
}

.bar-radio-empty {
  color: #95a8c0;
}

.bar-radio-status-grid {
  display: grid;
  gap: 9px;
  padding: 14px;
}

.bar-radio-status-item {
  display: grid;
  grid-template-columns: 12px minmax(0, 1fr) auto;
  align-items: center;
  gap: 10px;
  color: #cbd9eb;
}

.bar-radio-status-item strong {
  font-size: 0.72rem;
  color: #91a9c6;
}

.bar-radio-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
}

.bar-radio-dot.is-ok {
  background: #5df29a;
}

.bar-radio-dot.is-warn {
  background: #f2c66d;
}

.bar-radio-dot.is-error {
  background: #ff7272;
}

.bar-radio-card .bar-radio-stats-grid,
.bar-radio-card .bar-radio-health-status {
  padding: 14px;
}

.bar-radio-health-status {
  display: block;
  color: #f2c66d;
  font-weight: 900;
}

.bar-radio-card > span {
  display: block;
  padding: 0 14px 14px;
}

.bar-radio-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  min-height: 260px;
  color: #cbd9eb;
}

.bar-radio-loading span {
  width: 22px;
  height: 22px;
  border: 3px solid rgba(255, 255, 255, 0.15);
  border-top-color: #f2c66d;
  border-radius: 50%;
  animation: bar-radio-spin 0.8s linear infinite;
}

@keyframes bar-radio-spin {
  to {
    transform: rotate(360deg);
  }
}

@media (max-width: 980px) {
  .bar-radio-layout,
  .bar-radio-now {
    grid-template-columns: 1fr;
  }

  .bar-radio-cover-wrap {
    max-width: 360px;
  }
}

@media (max-width: 640px) {
  .bar-radio-page {
    width: min(100% - 20px, 1180px);
  }

  .bar-radio-header,
  .bar-radio-mini,
  .bar-radio-player-status {
    align-items: flex-start;
    flex-direction: column;
  }

  .bar-radio-live {
    white-space: normal;
  }

  .bar-radio-now,
  .bar-radio-header {
    padding: 16px;
  }

  .bar-radio-meta-grid,
  .bar-radio-stats-grid {
    grid-template-columns: 1fr;
  }
}
